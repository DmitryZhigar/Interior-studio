generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id Int @id @default(autoincrement())

  name String

  slug String @unique

  projects Project[]

  createdAt DateTime @default(now())
}

model Project {
  id Int @id @default(autoincrement())

  title String

  slug String @unique

  description String

  coverImage String

  categoryId Int

  category Category? @relation(fields: [categoryId], references: [id])

  images ProjectImage[]

  createdAt DateTime @default(now())
}

model ProjectImage {
  id Int @id @default(autoincrement())

  url String

  createdAt DateTime @default(now())

  projectId Int

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}
